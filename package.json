{
    "name": "apiWithClient",
    "version": "1.0.0",
    "engines": {
        "node": "25.8.0"
    },
    "scripts": {
        "install-reactjs": "npm install --prefix reactjs",
        "install-api": "npm install --prefix api",
        "build-reactjs": "npm run build --prefix reactjs",
        "heroku-postbuild": "npm run install-api && npm run install-reactjs && npm run build-reactjs",
        "start": "node api/server.js",
        "dev": "concurrently \"npm run api\" \"npm run react\"",
        "react": "npm start --prefix reactjs",
        "api": "nodemon api/server.js"
    },
    "dependencies": {
        "concurrently": "^9.2.1"
    }
}