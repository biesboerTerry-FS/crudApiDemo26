{
    "name": "apiWithClient",
    "version": "1.0.0",
    "engines": {
        "node": "25.8.0"
    },
    "scripts": {
        "install-reactjs": "npm install --prefix reactjs",
        "install-api": "npm install --prefix api",
        "build": "npm run build --prefix reactjs",
        "heroku-postbuild": "concurrently \"npm install-*\" \"npm build-*\"",
        "start": "npm start --prefix api",
        "dev:react": "concurrently --raw \"npm run api\" \"npm run react\"",
        "react": "cd reactjs && npm start",
        "api": "cd api && nodemon server.js"
    },
    "dependencies": {
        "concurrently": "^9.2.1"
    }
}
